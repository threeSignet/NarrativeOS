# === LLM 供应商配置 ===
# 兼容类型：openai-compatible / anthropic-compatible
LLM_COMPAT_TYPE=openai-compatible
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-api-key

# 轻量模型（默认，速度快、成本低，适合日常对话、简单生成）
LLM_MODEL_LIGHT=deepseek-v4-flash

# 高能模型（推理、复杂世界观设计、大纲生成等重任务时使用）
LLM_MODEL_HEAVY=deepseek-v4-pro

# === PostgreSQL 16 + pgvector ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=narrativeos
POSTGRES_PASSWORD=__REPLACE_ME__
POSTGRES_DB=narrativeos
DATABASE_URL=postgresql://narrativeos:__REPLACE_ME__@localhost:5432/narrativeos

# === Redis 7.2 ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=__REPLACE_ME__
REDIS_URL=redis://:__REPLACE_ME__@localhost:6379

# === MinIO（S3 兼容对象存储）===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=narrativeos_admin
MINIO_ROOT_PASSWORD=__REPLACE_ME__
MINIO_USE_SSL=false
MINIO_DEFAULT_BUCKET=narrativeos-assets

# === Embedding 配置（硅基流动 SiliconFlow）===
# 默认使用 SiliconFlow 的 BAAI/bge-m3（免费，1024维）
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=sk-your-siliconflow-api-key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# === 服务 ===
PORT=3000
TZ=Asia/Shanghai
NODE_ENV=development
LOG_LEVEL=debug
